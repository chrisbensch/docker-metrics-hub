# Copy this file to .env before starting the stack.

# Image tags. Use "latest" for easy first boot, then pin versions after the stack is working.
PROMETHEUS_IMAGE=prom/prometheus:latest
GRAFANA_IMAGE=grafana/grafana-oss:latest
BLACKBOX_EXPORTER_IMAGE=prom/blackbox-exporter:latest
ALERTMANAGER_IMAGE=prom/alertmanager:latest
PVE_EXPORTER_IMAGE=prompve/prometheus-pve-exporter:latest

# Web UI ports.
GRAFANA_BIND_ADDR=0.0.0.0
GRAFANA_PORT=3000
PROMETHEUS_BIND_ADDR=127.0.0.1
PROMETHEUS_PORT=9090
BLACKBOX_BIND_ADDR=127.0.0.1
BLACKBOX_PORT=9115
ALERTMANAGER_BIND_ADDR=127.0.0.1
ALERTMANAGER_PORT=9093
PVE_EXPORTER_BIND_ADDR=127.0.0.1
PVE_EXPORTER_PORT=9221

# Grafana login. Change this before exposing Grafana to your LAN.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-password
GRAFANA_ROOT_URL=http://localhost:3000

# Prometheus storage.
PROMETHEUS_RETENTION_TIME=30d
